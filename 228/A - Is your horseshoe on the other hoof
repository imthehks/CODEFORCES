#include <iostream>
using namespace std;
int main()
{
    long long s1{0}, s2{0}, s3{0}, s4{0};
    cin >> s1 >> s2 >> s3 >> s4;
    int mini{0};
 
    long long arr[4] = {s1, s2, s3, s4};
 
    for (int i = 0; i < 4; i++)
    {
        for (int j = i + 1; j < 4; j++)
        {
            if (arr[i] == arr[j])
            {
                mini++;
                break;
            }
        }
    }
 
    cout << mini << endl;
    return 0;
}